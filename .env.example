# Copy to .env and fill in values from Supabase Dashboard → Settings → API / Database
#
# Required for local API (employee create, admin routes on :8080):
#   SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY, SUPABASE_SERVICE_ROLE_KEY
# Run both frontend + API: pnpm dev:all
#
# Vercel (Production + Preview) — ALL from the SAME Supabase project:
#   VITE_SUPABASE_URL              = https://YOUR_REF.supabase.co  (build-time, frontend)
#   VITE_SUPABASE_PUBLISHABLE_KEY  = anon key                      (build-time, frontend)
#   SUPABASE_URL                   = same as VITE_SUPABASE_URL     (runtime, API)
#   SUPABASE_PUBLISHABLE_KEY       = same as VITE_PUBLISHABLE_KEY   (runtime, JWT verify)
#   SUPABASE_SERVICE_ROLE_KEY      = service_role secret           (runtime, API only — never VITE_*)
#
# After changing Vercel env vars you MUST redeploy (not just restart).
# Check API: GET /api/healthz/env — shows project refs match and lists missing vars.

# --- Cloud production (source) ---
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_DB_PASSWORD=your-database-password
# OLD_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- New cloud target (after creating project) ---
# NEW_DATABASE_URL=postgresql://postgres.[new-ref]:[password]@...
# NEW_SUPABASE_URL=https://[new-ref].supabase.co

# --- Local clone stacks (auto-configured by scripts) ---
OLD_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
NEW_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres
OLD_SUPABASE_URL=http://127.0.0.1:54321
NEW_SUPABASE_URL=http://127.0.0.1:55321

# Optional: Supabase CLI Management API (create projects / run cloud SQL)
# SUPABASE_ACCESS_TOKEN=your-personal-access-token

VITE_SUPABASE_URL=http://127.0.0.1:55321
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
VITE_SUPABASE_PROJECT_ID=pixel02-clone

SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-same-project-as-SUPABASE_URL
API_PORT=8080
NODE_ENV=development
