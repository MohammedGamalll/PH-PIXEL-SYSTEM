# Copy to .env and fill in values from Supabase Dashboard → Settings → API
#
# CRITICAL: all keys must be from ONE project (same ref in JWT payload).
# Variable names use UNDERSCORES (not hyphens):
#   SUPABASE_PUBLISHABLE_KEY   ✓
#   SUPABASE_PUBLISHABLE-KEY   ✗ wrong on Vercel
#
# Local: pnpm dev:all
#
# Vercel — set ALL five for Production + Preview, then Redeploy:
#   VITE_SUPABASE_URL              = https://YOUR_REF.supabase.co
#   VITE_SUPABASE_PUBLISHABLE_KEY  = anon (public) key
#   SUPABASE_URL                   = same as VITE_SUPABASE_URL
#   SUPABASE_PUBLISHABLE_KEY       = same anon key
#   SUPABASE_SERVICE_ROLE_KEY      = service_role secret (never VITE_*)
#
# Verify after deploy: GET https://YOUR_APP.vercel.app/api/healthz/env → "ok": true

# --- Cloud production (cywcdgwmngnnfotyivxz) ---
# SUPABASE_URL=https://cywcdgwmngnnfotyivxz.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# VITE_SUPABASE_URL=https://cywcdgwmngnnfotyivxz.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
# VITE_SUPABASE_PROJECT_ID=cywcdgwmngnnfotyivxz

