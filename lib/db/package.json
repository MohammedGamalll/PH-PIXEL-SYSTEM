{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "migrate:standalone-returns": "node scripts/run-session-standalone-returns-migration.mjs",
    "migrate:standalone-returns:new": "node scripts/run-session-standalone-returns-migration.mjs --target=new",
    "migrate:cloud": "node scripts/run-cloud-migration.mjs",
    "clone:supabase": "node scripts/clone-supabase-project.mjs",
    "sync:storage": "node scripts/sync-storage.mjs",
    "verify:clone": "node scripts/verify-clone-counts.mjs"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
