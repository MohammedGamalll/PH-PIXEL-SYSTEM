{
  "buildCommand": "NODE_ENV=production pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/pixel01 run build",
  "outputDirectory": "artifacts/pixel01/dist/public",
  "installCommand": "pnpm install",
  "functions": {
    "api/index.js": {
      "includeFiles": "artifacts/api-server/dist/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ]
}
